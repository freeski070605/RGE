{
  "name": "reemgrowth-engine",
  "version": "1.0.0",
  "description": "Autonomous marketing system for ReemTeam",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:all": "npm run build && npm run dashboard:build",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "worker:start": "node dist/workers/index.js",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "dashboard:preview": "npm --prefix dashboard run preview",
    "worker:intelligence": "ts-node src/workers/intelligenceWorker.ts",
    "worker:content": "ts-node src/workers/contentWorker.ts",
    "worker:media": "ts-node src/workers/mediaWorker.ts",
    "worker:scheduler": "ts-node src/workers/schedulerWorker.ts",
    "worker:all": "ts-node src/workers/index.ts",
    "test:integration": "tsx --test test/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bullmq": "^5.58.0",
    "canvas": "^3.2.0",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.1.5",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "openai": "^6.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.1",
    "@types/uuid": "^10.0.0",
    "mongodb-memory-server": "^11.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
