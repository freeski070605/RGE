{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "./dist-hq",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["apps/hq-api/src/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-hq"]
}
