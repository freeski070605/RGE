NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
# Set this to the exact MongoDB Atlas URI used by the original ReemTeam backend.
REEMTEAM_MONGODB_URI=
MONGODB_URI=mongodb://127.0.0.1:27017/reemteam-hq
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me
AUTH_COOKIE_NAME=reemteam_hq_session
HQ_INTERNAL_TOKEN=dev-token
OPERATOR_EMAIL=owner@reemteam.local
OPERATOR_PASSWORD=change-me
OPERATOR_NAME=ReemTeam Owner
PLAYER_SOURCE_COLLECTIONS=users,Users,user,User,hq_user_profiles,hq_users,players,Players,player,Player
PLAYER_IMPORT_LIMIT=10000
PLAYER_IMPORT_DRY_RUN=false
LEGACY_MONGODB_URI=
DEMO_SEED_ALLOW_REAL_DB=false
HQ_DUPLICATE_CLEANUP_DRY_RUN=true
HQ_DUPLICATE_CLEANUP_CONFIRM=
HQ_DUPLICATE_CLEANUP_USERNAME=
